{
    // ─── KiCad CLI path ─────────────────────────────────────────────────────
    // Update this if you have a different KiCad version installed.
    // Common paths:
    //   KiCad 10.0 → C:\\Program Files\\KiCad\\10.0\\bin\\kicad-cli.exe
    //   KiCad  9.0 → C:\\Program Files\\KiCad\\9.0\\bin\\kicad-cli.exe
    "kicad.cliPath": "C:\\Program Files\\KiCad\\10.0\\bin\\kicad-cli.exe",

    // ─── File associations ──────────────────────────────────────────────────
    // Treat KiCad S-expression files as Lisp for bracket matching & coloring.
    "files.associations": {
        "*.kicad_sch": "lisp",
        "*.kicad_pcb": "lisp",
        "*.kicad_mod": "lisp",
        "*.kicad_sym": "lisp",
        "*.kicad_wks": "lisp",
        "*.kicad_dru": "lisp",
        "*.kicad_pro": "toml"
    },

    // ─── Editor behaviour ───────────────────────────────────────────────────
    // Never auto-format KiCad files — the indentation is significant.
    "[lisp]": {
        "editor.formatOnSave": false,
        "editor.wordWrap": "off"
    },
    "[toml]": {
        "editor.formatOnSave": false
    },

    // ─── Explorer: hide auto-generated clutter ───────────────────────────────
    "files.exclude": {
        "**/*-backups": true,
        "**/fp-info-cache": true,
        "**/.history": true,
        "**/*.kicad_prl": true,
        "**/*~*.lck": true,
        "**/.gitkeep": true
    },

    // ─── Search: skip large auto-generated folders ───────────────────────────
    "search.exclude": {
        "**/*-backups": true,
        "**/fp-info-cache": true
    },

    // ─── Git ────────────────────────────────────────────────────────────────
    // Suppress "too many changes" warning that appears after KiCad saves.
    "git.ignoreLimitWarning": true
}
